class Relu:
    def __init__(self):
        self.mask = None #실수로 backward 먼저수행시 error.. 방지용 + 변수관리

    def forward(self, x):
        self.mask = (x<=0)
        out = x.copy
        out[self.mask] = 0 #out[] << 인덱싱임!

        return out
    
    def backward(self,dout):
        dout[self.mask] = 0 #forward를 무조건 작동시킨 상태에서 backpropagation하기 때문에 self.mask에 적용되어잇음.
        dx = dout
        return dx




class Affine:
    def __init__(self, W, b):
        self.W = W
        self.b = b

        self.x = None
        #역전파용
        self.originalx = None
        self.dW = None
        self.db = None

    def forward(self, x):
        #역전파용
        self.originalx = x.shape

        #Affine구현
        x = x.reshape(x.shape[0],-1)
        self.x = x

        out = np.dot(self.x, self.W) + self.b #중 ! 요

        return out
    
    def backward(self, dout):
        dx = np.dot(dout, self.W.T)
        self.dW = np.dot(self.x.T, dout)
        self.db = np.sum(dout, axis=0)
        
        dx = dx.reshape(*self.originalx)

        return dx

